{
  "name": "tara-matrix",
  "version": "2.0.0",
  "description": "TARA Matrix™ — Sistema Operativo Empresarial Conversacional",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "setup-db": "node setup-db.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "tara",
    "matrix",
    "saas",
    "conversational-ai"
  ],
  "author": "Alina Navarro",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "openai": "latest",
    "twilio": "^4.10.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "modules/**/*.js",
      "adapters/**/*.js"
    ],
    "coverageDirectory": "coverage",
    "verbose": true
  }
}
