# ─────────────────────────────────────────────────────────────────────────────
# TARA Matrix™ — Variables de entorno
# Copiar como .env y llenar los valores reales.
# NUNCA commitear el .env real al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Obtener en: Supabase → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Obtener en: platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# ── Twilio ────────────────────────────────────────────────────────────────────
# Obtener en: console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Número de WhatsApp con prefijo "whatsapp:"
# Sandbox Twilio: whatsapp:+14155238886
# Producción: whatsapp:+521XXXXXXXXXX
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# URL pública donde Twilio entrega los webhooks.
# CRÍTICO: debe coincidir EXACTAMENTE con lo configurado en Twilio Console.
# Desarrollo local con ngrok: https://xxxx.ngrok.io/webhook/twilio
# Producción en Render:       https://tara-matrix.onrender.com/webhook/twilio
# Si no se define, la validación de firma se omite (solo dev local).
WEBHOOK_URL_WHATSAPP=https://tara-matrix.onrender.com/webhook/twilio

# ── Empresa ───────────────────────────────────────────────────────────────────
# Slug que identifica a la empresa en Supabase (tabla companies)
COMPANY_SLUG=totalracks

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
