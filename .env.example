# ─────────────────────────────────────────────────────────────────────────────
# TARA Matrix™ — Variables de entorno
# Copiar como .env y llenar los valores reales.
# NUNCA commitear el .env real al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Obtener en: Supabase → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Obtener en: platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# ── Twilio ────────────────────────────────────────────────────────────────────
# Obtener en: console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Número de WhatsApp con prefijo "whatsapp:"
# Sandbox Twilio: whatsapp:+14155238886
# Producción: whatsapp:+521XXXXXXXXXX
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# URL pública donde Twilio entrega los webhooks.
# CRÍTICO: debe coincidir EXACTAMENTE con lo configurado en Twilio Console.
# Desarrollo local con ngrok: https://xxxx.ngrok.io/webhook/twilio
# Producción en Render:       https://tara-matrix.onrender.com/webhook/twilio
# Si no se define, la validación de firma se omite (solo dev local).
WEBHOOK_URL_WHATSAPP=https://tara-matrix.onrender.com/webhook/twilio

# ── Google Calendar (ANEXO A, TA.5) ───────────────────────────────────────────
# Obtener en: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# Debe coincidir EXACTAMENTE con un "Authorized redirect URI" del Client OAuth.
# Desarrollo local: http://localhost:3000/oauth/google/callback
# Producción:       https://tu-dominio/oauth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback

# Clave maestra para cifrar tokens OAuth en calendar_credentials (AES-256-GCM).
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 64 caracteres hex (32 bytes). NUNCA reusar entre entornos dev/prod.
CALENDAR_CREDENTIALS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Routing (FASE 3) ──────────────────────────────────────────────────────────
# COMPANY_SLUG fue eliminado en FASE 3. El routing es dinámico.
# Para registrar una empresa: INSERT en tabla channel_endpoints en Supabase.
# Ver: docs/architecture/phase-3/T3.1-channel-endpoints.md

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
